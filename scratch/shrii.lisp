(defmethod tri-app:cleanup-fn ((app shrii-1))
  (with-slots (shader-prog cbuffer vbuffer) app
    (when shader-prog
      (gl:delete-program shader-prog)
      (setq shader-prog nil))
    (when cbuffer
      (gl:delete-buffers (list cbuffer))
      (setq cbuffer nil))
    (when vbuffer
      (gl:delete-buffers (list vbuffer))
      (setq vbuffer nil))))


(defmethod tri-app:setup-fn ((app shrii-1))
  (with-slots (shader-prog
	       cbuffer vbuffer
	       vert-src frag-src
	       colors points theta
	       vcolor-idx vposition-idx
	       )
      app
    (when shader-prog (ignore-errors (gl:delete-program shader-prog)))
    (setq shader-prog
	  (link-program-from-shader-strings vert-src frag-src))
    (gl:enable :depth-test)
    (gl:depth-func :lequal)
    (gl:enable :blend)
    (gl:blend-func :src-alpha :one-minus-src-alpha)
    (gl:clear :color-buffer-bit :depth-buffer-bit)
    (when cbuffer (gl:delete-buffers (list cbuffer)))
    (when vbuffer (gl:delete-buffers (list vbuffer)))
    (let ((a (gl:gen-buffers 2)))
      (setq cbuffer (car a))
      (setq vbuffer (cadr a)))
    (gl:bind-buffer :array-buffer cbuffer)
    (send-buffer-data :array-buffer :static-draw colors)
    (setq vcolor-idx (gl:get-attrib-location shader-prog "vColor"))
    (gl:vertex-attrib-pointer vcolor-idx 4 :float nil 0 0)
    (gl:enable-vertex-attrib-array vcolor-idx)
    (gl:bind-buffer :array-buffer vbuffer)
    (send-buffer-data :array-buffer :static-draw points)
    (setq vposition-idx (gl:get-attrib-location shader-prog "vPosition"))
    (gl:vertex-attrib-pointer vposition-idx 3 :float nil 0 0)
    (gl:enable-vertex-attrib-array vposition-idx)
    (setq theta (gl:get-uniform-location shader-prog "theta"))))

(defmethod tri-app:update-fn ((app shrii-1) sdl-event)
  (let ((event-type (get-event-type sdl-event)))
    (format t "shri-event-handler  type=~A:~%" event-type)
    (when (member event-type '(:sdl-event-key-up
			       :sdl-event-key-down))
      (let ((key-ev (sdl-event-key sdl-event)))
	(format t "~A: scancode=~A ~&" event-type (sdl-keyboard-event-scancode key-ev))))))


(defmethod tri-app:draw-fn ((app shrii-1))
  (with-slots (shader-prog
	       theta view-rotx view-roty view-rotz angle
	       points)
      app
  (gl:use-program shader-prog)
  ;;  (gl:bind-vertex-array vertex-array)
  ;;(gl:clear-color 0.5 0.2 0.2 1.0)
  (gl:clear :color-buffer-bit :depth-buffer-bit)
  (cl-opengl-bindings:uniform-3f theta view-rotx view-roty view-rotz )
  (gl:draw-arrays :triangles 0 (/ (length points) 9))
  (gl:draw-arrays :lines (/ (length points) 9) (* 2 (/ (length points)9)))
  (gl:bind-vertex-array 0)
  (gl:use-program 0)))

(defmethod tri-app:resize-fn ((app shrii-1) new-width new-height)
  (let ((min (min new-height new-width)))
    (gl:viewport 0 0 min min)))

(defun toggle-depth-test ()
    (if (gl:enabledp :depth-test)
	(gl:disable :depth-test)
	(gl:enable :depth-test)))

